rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: simulations
    // Document ID: auto-generated simulationId
    // Fields:
    //   - name: string (required) - Name of the simulation
    //   - description: string (optional) - Description
    //   - createdAt: timestamp (required) - Creation time
    //   - updatedAt: timestamp (required) - Last update time
    //   - userId: string (required) - Owner UID
    //   - layers: list (required) - Array of Layer objects
    //   - interfaces: list (required) - Array of InterfaceDefect objects
    //   - imageUrl: string (optional) - AI generated image URL
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nguyendaivi9899@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidSimulation(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId == request.auth.uid &&
             data.layers is list && data.layers.size() <= 10 &&
             data.interfaces is list && data.interfaces.size() <= 10 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 2000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /simulations/{simulationId} {
      allow read, write: if true;
    }

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
